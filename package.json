{
  "name": "prueba-michael-page-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @apps/frontend",
    "build": "npm run build --workspace @apps/frontend",
    "start": "npm run start --workspace @apps/frontend",
    "lint": "npm run lint --workspace @apps/frontend",
    "dev:frontend": "npm run dev --workspace @apps/frontend",
    "dev:backend": "npm run start:dev --workspace @apps/backend"
  }
}