{
  "name": "prueba-michael-page-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @apps/frontend",
    "dev:all": "concurrently -n FRONTEND,BACKEND -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build --workspace @apps/frontend",
    "start": "npm run start --workspace @apps/frontend",
    "lint": "npm run lint --workspace @apps/frontend",
    "dev:frontend": "npm run dev --workspace @apps/frontend",
    "dev:backend": "npm run start:dev --workspace @apps/backend",
    "build:backend": "npm run build --workspace @apps/backend",
    "lint:backend": "npm run lint --workspace @apps/backend",
    "lint:all": "npm run lint --workspace @apps/frontend && npm run lint --workspace @apps/backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}